{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "rararulab": {
    "$description": "rara — soft pink, cute, feminine design tokens",
    "color": {
      "ink": {
        "$value": "#3D2B2E",
        "$type": "color",
        "$description": "Primary text, headings, brand mark — warm dark brown"
      },
      "muted": {
        "$value": "#8C7478",
        "$type": "color",
        "$description": "Secondary text, captions, metadata — dusty rose gray"
      },
      "subtle": {
        "$value": "#B8A0A4",
        "$type": "color",
        "$description": "Tertiary text, placeholders, disabled — soft mauve"
      },
      "line": {
        "$value": "#F0DEE0",
        "$type": "color",
        "$description": "Borders, dividers, separators — blush pink"
      },
      "surface": {
        "$value": "#FFFBFB",
        "$type": "color",
        "$description": "Cards, panels, elevated surfaces — warm white"
      },
      "bg": {
        "$value": "#FFF5F6",
        "$type": "color",
        "$description": "Page background — lightest pink tint"
      },
      "pop": {
        "$value": "#E8788A",
        "$type": "color",
        "$description": "Accent — CTAs, links, active states, highlights — coral pink"
      },
      "pop-hover": {
        "$value": "#D4606F",
        "$type": "color",
        "$description": "Accent hover/pressed state — deeper rose"
      },
      "ok": {
        "$value": "#7BC4A0",
        "$type": "color",
        "$description": "Success, passing, positive — soft mint green"
      },
      "warn": {
        "$value": "#E8B86D",
        "$type": "color",
        "$description": "Warning, caution — warm peach gold"
      },
      "err": {
        "$value": "#D46A6A",
        "$type": "color",
        "$description": "Error, failure, destructive — muted red"
      }
    },
    "ansi": {
      "$description": "Terminal ANSI 16-color mapping — rara pink palette",
      "black": { "$value": "#3D2B2E", "$type": "color" },
      "red": { "$value": "#D46A6A", "$type": "color" },
      "green": { "$value": "#7BC4A0", "$type": "color" },
      "yellow": { "$value": "#E8B86D", "$type": "color" },
      "blue": { "$value": "#9BAFD9", "$type": "color" },
      "magenta": { "$value": "#E8788A", "$type": "color" },
      "cyan": { "$value": "#85C7C9", "$type": "color" },
      "white": { "$value": "#F0DEE0", "$type": "color" },
      "bright-black": { "$value": "#8C7478", "$type": "color" },
      "bright-red": { "$value": "#E89090", "$type": "color" },
      "bright-green": { "$value": "#A0D9BF", "$type": "color" },
      "bright-yellow": { "$value": "#F0D090", "$type": "color" },
      "bright-blue": { "$value": "#B8CCE8", "$type": "color" },
      "bright-magenta": { "$value": "#F0A0B0", "$type": "color" },
      "bright-cyan": { "$value": "#A8D8D8", "$type": "color" },
      "bright-white": { "$value": "#FFF5F6", "$type": "color" }
    },
    "typography": {
      "family": {
        "sans": {
          "$value": "'Nunito', 'Inter', system-ui, -apple-system, sans-serif",
          "$type": "fontFamily"
        },
        "mono": {
          "$value": "'JetBrains Mono', 'SF Mono', 'Fira Code', ui-monospace, monospace",
          "$type": "fontFamily"
        }
      },
      "size": {
        "xs": { "$value": "0.75rem", "$type": "dimension" },
        "sm": { "$value": "0.85rem", "$type": "dimension" },
        "base": { "$value": "1rem", "$type": "dimension" },
        "md": { "$value": "1.1rem", "$type": "dimension" },
        "lg": { "$value": "1.4rem", "$type": "dimension" },
        "xl": { "$value": "2.2rem", "$type": "dimension" },
        "2xl": { "$value": "3.2rem", "$type": "dimension" },
        "3xl": { "$value": "4.5rem", "$type": "dimension" }
      },
      "weight": {
        "normal": { "$value": 400, "$type": "fontWeight" },
        "medium": { "$value": 500, "$type": "fontWeight" },
        "semibold": { "$value": 600, "$type": "fontWeight" },
        "bold": { "$value": 700, "$type": "fontWeight" }
      },
      "leading": {
        "tight": { "$value": "1.1", "$type": "number" },
        "snug": { "$value": "1.3", "$type": "number" },
        "normal": { "$value": "1.6", "$type": "number" },
        "loose": { "$value": "1.8", "$type": "number" }
      }
    },
    "spacing": {
      "0": { "$value": "0", "$type": "dimension" },
      "1": { "$value": "4px", "$type": "dimension" },
      "2": { "$value": "8px", "$type": "dimension" },
      "3": { "$value": "12px", "$type": "dimension" },
      "4": { "$value": "16px", "$type": "dimension" },
      "5": { "$value": "20px", "$type": "dimension" },
      "6": { "$value": "24px", "$type": "dimension" },
      "8": { "$value": "32px", "$type": "dimension" },
      "10": { "$value": "40px", "$type": "dimension" },
      "12": { "$value": "48px", "$type": "dimension" },
      "16": { "$value": "64px", "$type": "dimension" },
      "20": { "$value": "80px", "$type": "dimension" },
      "24": { "$value": "96px", "$type": "dimension" }
    },
    "radius": {
      "sm": { "$value": "6px", "$type": "dimension" },
      "md": { "$value": "12px", "$type": "dimension" },
      "lg": { "$value": "16px", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    },
    "motion": {
      "fast": { "$value": "150ms", "$type": "duration" },
      "normal": { "$value": "250ms", "$type": "duration" },
      "slow": { "$value": "500ms", "$type": "duration" }
    }
  }
}
